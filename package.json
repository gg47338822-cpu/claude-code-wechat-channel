{
  "name": "@xiaoyifu_0000/wechat-channel",
  "version": "1.0.4",
  "description": "WeChat Channel for Claude Code — bridge WeChat messages into Claude Code via the official iLink API",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "wechat-channel": "./dist/cli.js",
    "claude-code-wechat-channel": "./dist/cli.js"
  },
  "files": [
    "dist/",
    ".claude-plugin/",
    ".mcp.json",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs",
