    "dev": "npx tsx server.ts",
    "launch": "npx tsx launcher.ts",
    "test": "npx tsx --test test/unit.test.ts",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gg47338822-cpu/claude-code-wechat-channel"
